# Directory service
DIRECTORY_PORT=8081
DIRECTORY_DEBUG=false
INTERNAL_API_KEY=change_me_internal

# If set, overrides JWT_SECRET for directory token verification
# DIRECTORY_JWT_SECRET=

# CORS origins (comma-separated)
DIRECTORY_CORS_ORIGINS=https://your.domain

# Redis
REDIS_ADDR=127.0.0.1:6379
REDIS_USERNAME=
REDIS_PASSWORD=

