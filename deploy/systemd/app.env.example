# App server
PORT=8080
DEBUG=false
# ENV controls runtime behaviour:
#   production  — auth cookies are set with Secure=true (requires HTTPS)
#   development — Secure=false, safe for plain HTTP local dev
ENV=production
INTERNAL_API_KEY=change_me_internal

# JWT (must be same secret used to mint tokens)
JWT_SECRET=change_me
REFRESH_JWT_SECRET=change_me_refresh

# CORS origins (comma-separated)
CORS_ORIGINS=https://your.domain

# Redis
REDIS_ADDR=127.0.0.1:6379
REDIS_USERNAME=
REDIS_PASSWORD=

