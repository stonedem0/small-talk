[Unit]
Description=Small Talk - Frontend (Vite preview)
After=network.target

[Service]
User=ubuntu
Group=ubuntu
WorkingDirectory=/home/ubuntu/small-talk/apps/app/client
# Use npm preview; adjust to your production static server if needed
ExecStart=/usr/bin/npm run preview -- --host 0.0.0.0 --port 4173
Environment=NODE_ENV=production
Restart=always
RestartSec=3
KillSignal=SIGINT
TimeoutStopSec=20
NoNewPrivileges=true
SyslogIdentifier=small-talk-react

[Install]
WantedBy=multi-user.target

